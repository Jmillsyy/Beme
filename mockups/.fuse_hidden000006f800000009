  <main class="canvas-wrap">
    <div class="canvas">
      <div class="pdf">
        <div class="wall-h" style="left:60px; top:80px; width:340px;"></div>
        <div class="wall-v" style="left:60px; top:80px; height:280px;"></div>
        <div class="wall-h" style="left:60px; top:360px; width:340px;"></div>
        <div class="wall-v" style="left:386px; top:80px; height:280px;"></div>
        <div class="wall-h" style="left:200px; top:200px; width:120px;"></div>

        <span class="label" style="left:200px; top:64px;">4250 mm</span>
        <span class="label" style="left:32px; top:200px;">3100 mm</span>
        <span class="label" style="left:200px; top:344px;">4250 mm</span>
        <span class="label" style="left:430px; top:200px;">3100 mm</span>
        <span class="label" style="left:240px; top:184px;">1450 mm</span>

        <div class="marker" style="left:55px; top:75px;"></div>
        <div class="marker" style="left:381px; top:75px;"></div>
        <div class="marker" style="left:55px; top:355px;"></div>
        <div class="marker" style="left:381px; top:355px;"></div>
        <div class="marker tjct" style="left:194px; top:194px;"></div>

        <div class="opening" style="left:200px; top:80px; width:120px;"></div>

        <div class="pier" style="left:140px; top:70px;">T</div>
        <div class="pier" style="left:300px; top:70px;">T</div>
      </div>
    </div>
  </main>

  <aside class="inspector">
    <div class="insp-tabs">
      <div class="insp-tab active">Tally</div>
      <div class="insp-tab">Wall types</div>
      <div class="insp-tab">Piers</div>
    </div>

    <div class="insp-section">
      <div class="total-card">
        <div class="label">Total blocks</div>
        <div class="value">682</div>
        <div class="sub">7 walls · 28.4m run · 19.6m² openings</div>
      </div>
    </div>

    <div class="insp-section">
      <h3>Schedule</h3>
      <div class="tally-row"><span class="code">20.48</span><span class="name">H block</span><span class="count">418</span></div>
