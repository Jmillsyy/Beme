 * typical 2-5 area project, no realistic project hits 9+ floors.
 */
const AREA_PALETTE = [
  '#ef4444', // red
  '#3b82f6', // blue
  '#10b981', // emerald
  '#f59e0b', // amber
  '#8b5cf6', // violet
  '#14b8a6', // teal
