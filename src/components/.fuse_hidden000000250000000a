              : pagePicker.mode === 'append'
                ? `Add ${pagePicker.selected.size} page${pagePicker.selected.size === 1 ? '' : 's'}`
                : `Import ${pagePicker.selected.size} page${pagePicker.selected.size === 1 ? '' : 's'}`}
          </button>
        </div>
      </div>
    </div>
  )

  // ---------- Render: startup gate ----------
  //
